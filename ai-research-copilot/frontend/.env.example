####################################
# Application
####################################

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AI Research Copilot

####################################
# Database (PostgreSQL)
####################################

DATABASE_URL=postgresql://user:password@localhost:5432/ai_research_copilot?schema=public

####################################
# Supabase Authentication
####################################

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

####################################
# Stripe
####################################

# Secret key for server-side Stripe API calls
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Publishable key for client-side Stripe.js
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Webhook signing secret for verifying incoming webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

####################################
# URLs
####################################

# Stripe Checkout redirect URLs
NEXT_PUBLIC_STRIPE_SUCCESS_URL=http://localhost:3000/settings/billing?session_id={CHECKOUT_SESSION_ID}&success=true
NEXT_PUBLIC_STRIPE_CANCEL_URL=http://localhost:3000/settings/billing?canceled=true

# Stripe Customer Portal URL
NEXT_PUBLIC_STRIPE_PORTAL_URL=http://localhost:3000/settings/billing

####################################
# Backend (Python API)
####################################

NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

####################################
# Feature Flags
####################################

ENABLE_BILLING=true
