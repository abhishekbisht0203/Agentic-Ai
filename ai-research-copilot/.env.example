# Application Settings
APP_NAME=AI Research Copilot
APP_VERSION=1.0.0
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=debug

# Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database Settings
POSTGRES_USER=airc_user
POSTGRES_PASSWORD=airc_password
POSTGRES_DB=airc_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://airc_user:airc_password@localhost:5432/airc_db

# Redis Settings
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# Qdrant Vector Database
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333

# MinIO S3 Storage
MINIO_ROOT_USER=airc_admin
MINIO_ROOT_PASSWORD=airc_password
MINIO_BUCKET_NAME=airc-documents
MINIO_ENDPOINT=localhost:9000
MINIO_SECURE=false

# JWT Settings
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# OAuth Settings - GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# OAuth Settings - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth Settings - Microsoft
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# LLM Settings - OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# LLM Settings - Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# LLM Settings - Google Gemini
GOOGLE_API_KEY=your-google-api-key
GOOGLE_DEFAULT_MODEL=gemini-2.0-flash-exp

# MCP Settings
MCP_TIMEOUT=30
MCP_MAX_RETRIES=3

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://app.airesearchcopilot.com
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD_SECONDS=60

# Logging
LOG_FORMAT=json
LOG_FILE=/app/logs/app.log

# Celery Settings
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Frontend Settings
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Security
ENCRYPTION_KEY=your-encryption-key-32-chars-minimum
BCRYPT_ROUNDS=12

# Email Settings (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@airesearchcopilot.com

# Feature Flags
ENABLE_MCP=true
ENABLE_RAG=true
ENABLE_WORKFLOWS=true
ENABLE_ANALYTICS=true