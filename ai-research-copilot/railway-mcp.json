{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "docker/mcp/Dockerfile.railway"
  },
  "deploy": {
    "startCommand": "uvicorn app.mcp.server.main:app --host 0.0.0.0 --port $PORT --workers 2 --log-level info",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
